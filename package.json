{
  "name": "@galva/react-native",
  "version": "0.1.0",
  "description": "React Native SDK for Galva — subscription retention platform",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./in-app-message": {
      "source": "./src/in-app-message/index.ts",
      "types": "./lib/typescript/in-app-message/index.d.ts",
      "default": "./lib/module/in-app-message/index.js"
    },
    "./react": {
      "source": "./src/react/index.ts",
      "types": "./lib/typescript/react/index.d.ts",
      "default": "./lib/module/react/index.js"
    },
    "./package.json": "./package.json",
    "./app.plugin.js": "./app.plugin.js"
  },
  "typesVersions": {
    "*": {
      "in-app-message": [
        "./lib/typescript/in-app-message/index.d.ts"
      ],
      "react": [
        "./lib/typescript/react/index.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "*.podspec",
    "galva.lock.json",
    "app.plugin.js",
    "in-app-message.js",
    "react.js",
    "plugin/build",
    "scripts",
    "react-native.config.js",
    "docs",
    "!ios/galva-src/Package.swift.ref",
    "!ios/build",
    "!ios/Pods",
    "!android/build",
    "!android/.gradle",
    "!**/__tests__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json",
    "lint": "eslint .",
    "gen:bridge": "bun scripts/gen-bridge.ts",
    "check:bridge": "bun scripts/gen-bridge.ts --check",
    "test:ios": "bash scripts/test-autowire.sh",
    "test:ios:e2e": "bash scripts/test-autowire-e2e.sh",
    "test:plugin": "bun scripts/test-plugin.ts",
    "test:expo:prebuild": "bun scripts/test-expo-prebuild.ts",
    "test:expo:runtime": "bash scripts/test-expo-runtime.sh",
    "format": "prettier --write \"**/*.{js,mjs,ts,tsx,md,json}\"",
    "build": "bob build && tsc -p plugin",
    "clean": "del-cli lib plugin/build",
    "sync-galva": "bash scripts/sync-galva.sh",
    "prepare": "bob build && tsc -p plugin"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "galva",
    "subscription",
    "retention",
    "in-app-message"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galva-io/galva-react-native.git"
  },
  "author": "Galva <dev@galva.io> (https://github.com/Galva-io)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Galva-io/galva-react-native/issues"
  },
  "homepage": "https://github.com/Galva-io/galva-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "example"
  ],
  "galva": {
    "iosCoreRepo": "https://github.com/Galva-io/galva-ios.git",
    "iosCoreRef": "main",
    "iosCoreCommit": "5b35ab621dca9c403b1da3dd78d3525e4997f092"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@expo/config-plugins": "^56.0.9",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "bun": "1.3.3",
    "del-cli": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.6.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.42.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
