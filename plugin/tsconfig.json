{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "build",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2021",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src"]
}
