{
  "git": {
    "commitMessage": "chore: release ${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": ["main", "develop"]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": true
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": [
      "npm run lint",
      "npm run typecheck",
      "npm run parity-check"
    ]
  }
}
