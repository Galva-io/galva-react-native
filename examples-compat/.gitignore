# The packed library tarball (regenerated by setup.sh; referenced as
# file:../.galva/galva-react-native.tgz from each app's package.json — a real
# dependency entry is REQUIRED for RN autolinking, which scans package.json).
.galva/

# Lockfiles churn on every setup.sh run (the tarball integrity hash changes
# with each pack); versions are pinned tightly enough by each package.json.
*/package-lock.json
